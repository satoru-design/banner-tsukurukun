generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Banner {
  id          String   @id @default(cuid())
  productName String?
  lpUrl       String?
  target      String?
  mainCopy    String?
  subCopy     String?
  elements    String?  // JSON serialized drag & drop elements
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
